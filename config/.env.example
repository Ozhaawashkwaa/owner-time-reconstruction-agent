# ===================================================================
# Owner Time Reconstruction Agent — Variables d'environnement
# ===================================================================
# Copier ce fichier vers .env et remplir les valeurs
# Ne JAMAIS commiter .env (c'est dans .gitignore)
# ===================================================================

# --- Anthropic API (pour génération messages conversationnels) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Slack Bridge (déployé sur Railway) ---
# URL publique de ton app Railway
SLACK_BRIDGE_URL=https://[ton-app].railway.app

# Channel Slack où poster (format: ID Slack, pas nom)
TIME_TRACKING_CHANNEL=C091...

# Token Slack (utile si on doit poster directement, sinon passe par bridge)
SLACK_BOT_TOKEN=xoxb-...

# --- Google Sheet State Store ---
STATE_SPREADSHEET_ID=1XHrhhoQIbPNVvsH6-kQMcNTa52rtFdNAFtqng4JnxLM

# --- Google Drive ---
# Folder où sont stockées les .db ActivityWatch
AW_DRIVE_FOLDER_ID=1f4XFaYCrUDzu5MmUcu_ZVAh4x1hqOujS

# --- ClickUp ---
# Workspace ID (à récupérer via clickup_get_workspace_hierarchy)
CLICKUP_WORKSPACE_ID=

# Franck's user ID dans ClickUp
CLICKUP_USER_ID=4205656

# --- Timezone ---
TIMEZONE=America/Toronto

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/routine.log

# --- Routine behavior ---
# Heure de déclenchement (format cron 0-23)
ROUTINE_TRIGGER_HOUR=7
# Retry interval en minutes si .db pas dispo
ROUTINE_RETRY_MINUTES=30
# Max retries
ROUTINE_MAX_RETRIES=4

# --- Test/Debug ---
# Si true, ne pas vraiment poster vers Slack ou ClickUp
DRY_RUN=false
